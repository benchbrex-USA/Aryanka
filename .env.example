# Supabase - https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend - https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=hello@aryanka.io
RESEND_FROM_NAME=Aryanka

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Aryanka

# Stripe - https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_pro_annual_price_id

# Cron security (any random string, e.g. openssl rand -hex 32)
CRON_SECRET=your_random_secret_for_cron_authorization

# Optional: Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# LinkedIn OAuth - https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Twitter/X OAuth 2.0 - https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Reddit OAuth - https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Google/YouTube OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Instagram/Meta OAuth - https://developers.facebook.com/apps
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# Medium OAuth - https://medium.com/developers/oauth-2-0
MEDIUM_CLIENT_ID=your_medium_client_id
MEDIUM_CLIENT_SECRET=your_medium_client_secret

# Claude API (for AI blog generation) - https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# Lead enrichment - https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key

# Slack notifications - https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Canva integration (coming soon) - https://www.canva.com/developers
CANVA_API_KEY=your_canva_api_key
